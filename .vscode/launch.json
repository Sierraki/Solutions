{
    "version": "0.2.0",
    "configurations": [
        {
            // === C++ 配置 (使用 MSVC) ===
            "name": "C++ (Windows/MSVC)",
            "type": "cppvsdbg", 
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "console": "externalTerminal" // 推荐：C++ 用独立黑窗口运行
        },
        {
            // === Python 配置 ===
            "name": "Python: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal" // 推荐：Python 直接在下方终端显示
        }
    ]
}